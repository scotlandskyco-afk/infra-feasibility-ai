# Database
DATABASE_URL=postgresql://ggc_user:ggc_pass@db:5432/infra_db

# JWT
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# World Bank API (no key required — public)
WORLD_BANK_BASE_URL=https://api.worldbank.org/v2

# NASA POWER API (no key required — public)
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# ElectricityMap (requires free API key from electricitymap.org)
ELECTRICITYMAP_API_KEY=your-electricitymap-key
ELECTRICITYMAP_BASE_URL=https://api.electricitymap.org/v3

# Cache
CACHE_DIR=cache
CACHE_TTL_HOURS=24

# Redis (optional — comment out to use local JSON cache)
# REDIS_URL=redis://redis:6379
